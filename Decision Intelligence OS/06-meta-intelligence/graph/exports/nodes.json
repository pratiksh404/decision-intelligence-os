    {
      "id": "MMD-001",
      "type": "mental-model",
      "label": "First Principles",
      "status": "active",
      "properties": {
        "entity_id": "MMD-001",
        "entity_type": "mental-model",
        "title": "First Principles",
        "subtype": "first-principles",
        "status": "active",
        "description": "Decompose problems to their fundamental, axiomatic truths and reason up from there. Reject inherited assumptions, analogies, and conventional wisdom as starting points. Ask: \"What do I know to be absolutely true here?\"\n",
        "core_question": "What would have to be true for this to be correct, and how do I know that?",
        "application_protocol": "1. State the claim or problem as clearly as possible\n2. List all assumptions embedded in the claim\n3. Challenge each assumption: \"How do I know this is true?\"\n4. Strip away everything that is assumed, analogized, or inherited\n5. Identify the irreducible facts\n6. Rebuild reasoning from those facts upward\n",
        "failure_modes": "Can become paralytic \u2014 stripping to first principles on every decision wastes time. Use when the conventional approach is clearly wrong or producing bad outcomes. Overuse leads to reinventing wheels unnecessarily.\n",
        "complementary_models": [
          "MMD-007",
          "MMD-008"
