    {
      "id": "MMD-002",
      "type": "mental-model",
      "label": "Power Laws",
      "status": "active",
      "properties": {
        "entity_id": "MMD-002",
        "entity_type": "mental-model",
        "title": "Power Laws",
        "subtype": "power-laws",
        "status": "active",
        "description": "In many systems, a small number of inputs produce a disproportionately large share of outputs. 20% of decisions produce 80% of results. 1% of customers generate 50% of revenue. Focus obsessively on identifying and exploiting the dominant few.\n",
        "core_question": "Where is the 20% that produces 80% of the outcome?",
        "application_protocol": "1. List all inputs, customers, decisions, or activities\n2. Rank by output contribution\n3. Identify if distribution is power-law shaped (top few dominate)\n4. Concentrate resources on top-ranked items\n5. Ruthlessly eliminate or minimize bottom-ranked items\n6. Periodically re-rank as the system evolves\n",
        "failure_modes": "Can lead to over-concentration and fragility if the dominant few fail. Power law distributions shift \u2014 today's top input may not be tomorrow's. Misidentifying what to measure causes optimization on the wrong axis.\n",
        "complementary_models": [
          "MMD-004",
