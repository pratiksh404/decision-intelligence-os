    {
      "id": "MMD-005",
      "type": "mental-model",
      "label": "Incentives",
      "status": "active",
      "properties": {
        "entity_id": "MMD-005",
        "entity_type": "mental-model",
        "title": "Incentives",
        "subtype": "incentives",
        "status": "active",
        "description": "All behavior is driven by incentives \u2014 explicit and implicit, financial and social, short-term and long-term. To predict behavior, model the incentive structures. To change behavior, change the incentives. \"Never attribute to malice what can be explained by incentives.\"\n",
        "core_question": "What does this person/organization get rewarded for doing?",
        "application_protocol": "1. Identify all stakeholders in the system\n2. For each stakeholder, list their explicit incentives (what they're paid/measured on)\n3. List implicit incentives (status, safety, social approval, avoiding blame)\n4. Identify misaligned incentives (where their incentive conflicts with your goal)\n5. Design around misalignments or create new incentive structures\n6. Predict behavior: follow the incentive trail\n",
        "failure_modes": "Assumes people are purely rational incentive-maximizers. Ignores genuine altruism, values-based behavior, and professional norms. Over-focus on financial incentives misses status and social incentives.\n",
