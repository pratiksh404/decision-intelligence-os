{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "obsidian": {
      "type": "local",
      "command": ["npx", "-y", "mcp-obsidian"],
      "enabled": true,
      "environment": {
        "OBSIDIAN_VAULT_PATH": "/Users/pratiksh/Documents/work/decision-intelligence-os/vault",
        "OBSIDIAN_API_KEY": "{env:OBSIDIAN_API_KEY}"
      }
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx", "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/pratiksh/Documents/work/decision-intelligence-os"
      ],
      "enabled": true
    },
    "git": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-git"],
      "enabled": true,
      "environment": {
        "GIT_REPO_PATH": "/Users/pratiksh/Documents/work/decision-intelligence-os"
      }
    },
    "firecrawl": {
      "type": "local",
      "command": ["npx", "-y", "firecrawl-mcp"],
      "enabled": true,
      "environment": {
        "FIRECRAWL_API_KEY": "{env:FIRECRAWL_API_KEY}"
      }
    }
  }
}
