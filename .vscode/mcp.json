{
  "inputs": [
    {
      "type": "promptString",
      "id": "obsidian-api-key",
      "description": "Obsidian Local REST API Key",
      "password": true
    },
    {
      "type": "promptString",
      "id": "firecrawl-api-key",
      "description": "Firecrawl API Key",
      "password": true
    }
  ],
  "servers": {
    "obsidian": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-obsidian"],
      "env": {
        "OBSIDIAN_VAULT_PATH": "/Users/pratiksh/Documents/work/decision-intelligence-os/vault",
        "OBSIDIAN_API_KEY": "${input:obsidian-api-key}"
      }
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/pratiksh/Documents/work/decision-intelligence-os"
      ]
    },
    "git": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-git"],
      "env": {
        "GIT_REPO_PATH": "/Users/pratiksh/Documents/work/decision-intelligence-os"
      }
    },
    "firecrawl": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "${input:firecrawl-api-key}"
      }
    }
  }
}
